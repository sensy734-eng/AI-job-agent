APP_NAME=AI Job Agent
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# SQLite fallback, safe for local demos.
DATABASE_URL=sqlite:///./job_agent.db
VECTOR_BACKEND=sqlite
EMBEDDING_DIMENSION=512

# OpenAI-compatible LLM. Fill locally only.
LLM_PROVIDER=offline
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Embeddings are independent from the chat model.
# local uses sentence-transformers when optional local dependencies are installed.
# If local model loading fails, the app falls back to offline hashing.
EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=backend/models/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_FALLBACK=offline-hashing

# Optional pgvector integration test database.
PGVECTOR_TEST_DATABASE_URL=
